#!/bin/bash
# Custom login shell for the deploy user.
# Auto-creates bare repos on first push.
# Only allows git-receive-pack (no interactive login).

set -euo pipefail

DEPLOY_HOME="/home/deploy"

if [ "${1:-}" != "-c" ] || [ -z "${2:-}" ]; then
  echo "Interactive login not allowed. Use: git push deploy@server:app-name"
  exit 1
fi

CMD="$2"

# Only allow git-receive-pack
if [[ "$CMD" =~ ^git-receive-pack\ \'(.+)\'$ ]]; then
  REPO_NAME="${BASH_REMATCH[1]}"
  REPO_NAME="${REPO_NAME%.git}"  # strip .git suffix if present
  REPO_PATH="${DEPLOY_HOME}/${REPO_NAME}"

  # Auto-create bare repo on first push
  if [ ! -d "$REPO_PATH" ]; then
    git init --bare "$REPO_PATH" >/dev/null 2>&1
    ln -sf "${DEPLOY_HOME}/pre-receive-hook" "$REPO_PATH/hooks/pre-receive"
    echo "▶ Created new app: ${REPO_NAME}" >&2
  fi

  exec git-receive-pack "$REPO_PATH"
else
  echo "Command not allowed."
  exit 1
fi
